# WeatherAir Vienna - local environment template
# Copy this file to .env and replace placeholder values locally.
# Do not commit real secrets.

# MongoDB
MONGO_ROOT_USERNAME=change_me
MONGO_ROOT_PASSWORD=change_me
MONGO_DB=weatherair_vienna
MONGO_PORT=27017

# External APIs
# Open-Meteo (weather + air quality) and Geosphere endpoints require no API token.

# Latitude and longitude for Vienna (used in API requests)
WIEN_LAT = 48.2082
WIEN_LON = 16.3738

# Runtime
TZ=Europe/Vienna

# Optional
JUPYTER_TOKEN=optional_local_token